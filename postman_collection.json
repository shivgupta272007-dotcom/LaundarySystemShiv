{
  "info": {
    "name": "LaundryFlow API",
    "description": "Mini Laundry Order Management System — API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Prices",
      "item": [
        {
          "name": "Get Price List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/prices"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Raj Sharma\",\n  \"phoneNumber\": \"9876543210\",\n  \"garments\": [\n    { \"garmentType\": \"Shirt\", \"quantity\": 3 },\n    { \"garmentType\": \"Pants\", \"quantity\": 2 }\n  ],\n  \"notes\": \"Stain on collar\"\n}"
            }
          }
        },
        {
          "name": "List All Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Filter Orders by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?status=RECEIVED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "status", "value": "RECEIVED" }
              ]
            }
          }
        },
        {
          "name": "Filter Orders by Customer",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?customer=Raj",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "customer", "value": "Raj" }
              ]
            }
          }
        },
        {
          "name": "Filter Orders by Phone",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?phone=987",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "phone", "value": "987" }
              ]
            }
          }
        },
        {
          "name": "Filter Orders by Garment Type",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?garmentType=Shirt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "garmentType", "value": "Shirt" }
              ]
            }
          }
        },
        {
          "name": "Get Single Order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/LD-00001"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/orders/LD-00001/status",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PROCESSING\"\n}"
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/orders/LD-00001"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    }
  ]
}
